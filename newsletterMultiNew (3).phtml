            <option value="all">All</option>
            <option value="on">With Picture</option>
            <option value="off">Without Picture</option>
          </select>
        </div>
        <div class="nl-field">
          <label for="filter_fake_msg_count">Fake Msg Count</label>
          <input id="filter_fake_msg_count" type="number" data-sf="filter_fake_msg_count" class="nl-input" placeholder="Number of messages">
        </div>
      </div>

      <div class="nl-grid" style="margin-top:16px; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));">
        <div class="nl-checkbox-row"><input type="checkbox" id="filter_online" data-sfc="online"><label for="filter_online" style="cursor:pointer;font-size:.88rem;">Online now</label></div>
        <div class="nl-checkbox-row"><input type="checkbox" id="filter_premium" data-sfc="premium"><label for="filter_premium" style="cursor:pointer;font-size:.88rem;">Premium</label></div>
        <div class="nl-checkbox-row"><input type="checkbox" id="filter_verified" data-sfc="verified"><label for="filter_verified" style="cursor:pointer;font-size:.88rem;">Verified</label></div>
        <div class="nl-checkbox-row"><input type="checkbox" id="filter_ispaid" data-sfc="is_paid"><label for="filter_ispaid" style="cursor:pointer;font-size:.88rem;">Paid</label></div>
        <div class="nl-checkbox-row"><input type="checkbox" id="filter_notpaid" data-sfc="notpaid"><label for="filter_notpaid" style="cursor:pointer;font-size:.88rem;">Not Paid</label></div>
      </div>

      <div class="nl-field" style="margin-top:16px;">
        <label for="filter_user_intrest">Interests</label>
        <select id="filter_user_intrest" data-sf="filter_user_intrest" class="nl-select js-example-basic-multiple" name="filter_user_intrest[]" multiple="multiple">
          <option value="37">Seitensprung</option>
          <option value="301">Quickie</option>
          <option value="302">Kuschelsex</option>
          <option value="7">Partnertausch</option>
          <option value="33">Realtreffen</option>
          <option value="32">OneNightStand</option>
          <option value="303">Ficktreffen</option>
          <option value="304">Liebe</option>
          <option value="305">Partnertschaft</option>
          <option value="306">Küsse</option>
          <option value="35">Beziehung</option>
          <option value="307">Kennenlernen</option>
          <option value="308">Abenteuer</option>
        </select>
      </div>
    </div>
  </section>

  <!-- ========== SELECTED USERS BAR ========== -->
  <section class="nl-selected-bar" id="nlSelectedBar" style="display:none;">
    <i class="material-icons">check_circle</i>
    <span class="nl-selected-bar__count"><span data-selected-users-total>0</span> users selected</span>
    <div class="nl-selected-bar__avatars" data-checkedUsers-photos></div>
    <button type="button" class="nl-btn nl-btn--success" id="nlComposeBtn" style="background:#fff;color:var(--nl-primary);">
      <i class="material-icons" style="font-size:18px">edit</i> Compose Multi-Message
    </button>
  </section>

  <!-- ========== USERS TABLE ========== -->
  <section class="nl-panel">
    <div class="nl-panel__head">
      <div class="nl-panel__title">
        <i class="material-icons">people</i>
        <span>User Search Results <span id="totalResult" style="color:var(--nl-muted);font-weight:400;"></span></span>
      </div>
      <span id="nlSearchStatus" style="font-size:.85rem;color:var(--nl-muted);"></span>
    </div>
    <div class="nl-table-wrap">
      <table class="nl-table">
        <thead>
          <tr>
            <th style="width:42px;">
              <input type="checkbox" id="nlCheckAll" onclick="checkAll(this)" data-target="#usersTable" style="width:18px;height:18px;accent-color:var(--nl-primary);cursor:pointer;">
            </th>
            <th>Full name</th>
            <th>Location</th>
            <th>Mails</th>
            <th>Last activity</th>
            <th>Credits</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody id="usersTable">
          <tr><td colspan="7"><div class="nl-empty">Run a search to load users.</div></td></tr>
        </tbody>
      </table>
    </div>
    <div class="nl-pagination">
      <div>
        Showing <span data-current-view-users>0</span> of <span data-current-total-users>0</span> results
      </div>
      <div style="display:flex;gap:8px;">
        <button data-backPage-user-search disabled><i class="material-icons" style="font-size:18px;vertical-align:middle">chevron_left</i> Prev</button>
        <button data-nextPage-user-search><i class="material-icons" style="font-size:18px;vertical-align:middle">chevron_right</i> Next</button>
      </div>
    </div>
  </section>

  <!-- ========== COMPOSER ========== -->
  <section class="nl-composer" id="nlComposer">
    <div class="nl-composer__head">
      <i class="material-icons" style="color:var(--nl-primary);">mail</i>
      <h3>Multi-Message Newsletter</h3>
      <span style="margin-left:auto;font-size:.82rem;color:var(--nl-muted);">Drag rows to reorder · Auto-saved as draft</span>
    </div>

    <form id="auto_message_form_welcome" method="post" enctype="multipart/form-data">
      <input type="hidden" name="action" value="update_auto_message_multinewsletter_settings_new">
      <input type="hidden" name="index" value="<?= $optIndex ?>">
      <input type="hidden" id="multinewsletter_<?= $optIndex ?>_message_active" name="multinewsletter_<?= $optIndex ?>_message_active">

      <div class="nl-msg-list" id="messageRows">
        <!-- rows injected by JS -->
      </div>

      <div class="nl-composer__foot">
        <button type="button" class="nl-btn nl-btn--ghost" id="addMessageRow">
          <i class="material-icons" style="font-size:18px">add</i> Add Message
        </button>
        <div class="nl-schedule">
          <i class="material-icons" style="color:var(--nl-muted);">schedule</i>
          <label for="nlScheduleDateTime" style="font-size:.85rem;color:var(--nl-muted);">Schedule:</label>
          <input type="text" id="nlScheduleDateTime" name="nlScheduleDateTime"
                 placeholder="Send immediately (or pick a time)"
                 data-toggle="flatpickr" data-flatpickr-mode="single"
                 data-flatpickr-alt-input="true" data-flatpickr-enable-time="true"
                 data-flatpickr-time-24hr="true"
                 data-flatpickr-alt-format="Y-m-d H:i:s"
                 data-flatpickr-date-format="Y-m-d H:i:s"
                 data-flatpickr-min-date="<?= date('Y-m-d H:i:s') ?>">
        </div>
        <button type="button" class="nl-btn nl-btn--primary" id="auto_message_save_multinewsletter_btn">
          <i class="material-icons" style="font-size:18px">send</i> Create &amp; Queue Newsletter
        </button>
      </div>
    </form>
  </section>
</div>

<!-- Toast container -->
<div class="nl-toast-wrap" id="nlToastWrap"></div>

<script>
/* ==================================================================
 * NewsletterMulti — Optimized vanilla + jQuery hybrid
 * - All hot paths use vanilla JS for speed
 * - Event delegation for dynamic rows
 * - Debounced inputs
 * - HTML5 drag-and-drop row reordering
 * ================================================================== */
(function () {
  'use strict';

  const OPT_INDEX = '<?= $optIndex ?>';
  const VALID_EXTS = ['jpg','jpeg','png','gif','bmp','webp','tiff','mp4','webm','ogg','mov','avi','mkv','flv'];
  const DELAY_OPTIONS = [
    {label:'-- Select --', value:0},
    ...Array.from({length:60}, (_,i)=>({label:`${i+1} Min`, value:i+1})),
    {label:'1 Hour',  value:60},
    {label:'3 Hours', value:180},
    {label:'6 Hours', value:360},
    {label:'9 Hours', value:540},
    {label:'12 Hours',value:720},
    {label:'1 Day',   value:1440},
    {label:'2 Days',  value:2880},
    {label:'3 Days',  value:4320},
    {label:'1 Week',  value:10080},
  ];

  /* ---------- Toast system ---------- */
  function toast(msg, type='info') {
    const wrap = document.getElementById('nlToastWrap');
    const el = document.createElement('div');
    el.className = `nl-toast nl-toast--${type}`;
    const icon = type === 'success' ? 'check_circle'
               : type === 'error'   ? 'error'
               : type === 'warn'    ? 'warning'
               : 'info';
    el.innerHTML = `
      <i class="material-icons" style="color:var(--nl-${type==='warn'?'warn':type==='error'?'danger':type==='success'?'success':'primary'})">${icon}</i>
      <div class="nl-toast__msg">${msg}</div>
      <button class="nl-toast__close">&times;</button>
    `;
    el.querySelector('.nl-toast__close').addEventListener('click', () => el.remove());
    wrap.appendChild(el);
    setTimeout(() => { el.style.opacity='0'; el.style.transform='translateX(20px)'; setTimeout(()=>el.remove(),300); }, 4500);
  }
  // Backward-compat helper for older code that called dislayAlert
  window.dislayAlert = (m) => toast(m, 'info');

  /* ---------- Build a single message row ---------- */
  function buildRow(num, data = {}) {
    const row = document.createElement('div');
    row.className = 'nl-msg-card';
    row.draggable = true;
    row.dataset.msgNum = num;

    const type = data.type || 'text_image';
    const text = data.text || '';
    const delay = data.delay ?? 0;
    const img = data.image || '';

    const delayOpts = DELAY_OPTIONS.map(o =>
      `<option value="${o.value}" ${Number(delay)===o.value?'selected':''}>${o.label}</option>`
    ).join('');

    const typeOpts = ['text','image','text_image'].map(t =>
      `<option value="${t}" ${t===type?'selected':''}>${t==='text_image'?'Text + File':t.charAt(0).toUpperCase()+t.slice(1)}</option>`
    ).join('');

    row.innerHTML = `
      <div class="nl-msg-card__head">
        <div class="nl-msg-num">${num}</div>
        <div class="nl-msg-type">
          <select data-field="msg_type" name="multinewsletter_${OPT_INDEX}_msg_type_${num}">${typeOpts}</select>
        </div>
        <div class="nl-msg-delay">
          <label>Delay</label>
          <select data-field="delay" name="multinewsletter_${OPT_INDEX}_${num}">${delayOpts}</select>
        </div>
        <button type="button" class="nl-remove-row" title="Remove" ${num===1?'disabled':''}>
          <i class="material-icons">delete</i>
        </button>
      </div>
      <div class="nl-msg-body">
        <textarea data-field="message" name="multinewsletter_${OPT_INDEX}_message_${num}"
                  placeholder="Type your message here..." style="display:${type==='image'?'none':'block'};">${text}</textarea>
        <label class="nl-file-zone" style="display:${type==='text'?'none':'flex'};">
          <i class="material-icons" style="color:var(--nl-muted);">cloud_upload</i>
          <span>Click to upload image / video</span>
          <input type="file" data-field="file" name="multinewsletter_${OPT_INDEX}_file_${num}"
                 accept="image/*,video/*">
          <input type="hidden" data-field="file_hidden" name="multinewsletter_${OPT_INDEX}_file_${num}_hidden" value="${img}">
        </label>
        <div class="nl-file-preview" data-field="preview"></div>
      </div>
    `;

    // Wire up interactions
    const typeSel = row.querySelector('[data-field="msg_type"]');
    const fileInput = row.querySelector('[data-field="file"]');
    const fileZone = row.querySelector('.nl-file-zone');
    const textarea = row.querySelector('[data-field="message"]');
    const previewBox = row.querySelector('[data-field="preview"]');

    typeSel.addEventListener('change', () => {
      const v = typeSel.value;
      textarea.style.display = (v === 'image') ? 'none' : 'block';
      fileZone.style.display = (v === 'text')   ? 'none' : 'flex';
    });

    fileInput.addEventListener('change', () => {
      const f = fileInput.files[0];
      if (!f) return;
      const ext = f.name.split('.').pop().toLowerCase();
      if (!VALID_EXTS.includes(ext)) {
        toast(`Invalid file type: .${ext}`, 'error');
        fileInput.value = '';
        return;
      }
      // Show preview
      const url = URL.createObjectURL(f);
      if (f.type.startsWith('image/')) {
        previewBox.innerHTML = `<img src="${url}" alt="preview">`;
      } else if (f.type.startsWith('video/')) {
        previewBox.innerHTML = `<video src="${url}" controls></video>`;
      } else {
        previewBox.innerHTML = `<div style="font-size:.82rem;color:var(--nl-muted);">${f.name}</div>`;
      }
    });

    // If existing image, show preview
    if (img) {
      const ext = img.split('.').pop().toLowerCase();
      const fullUrl = (window.location.origin + '/requests/' + img).replace(/\/+/g,'/');
      if (['jpg','jpeg','png','gif','bmp','webp','tiff'].includes(ext)) {
        previewBox.innerHTML = `<img src="${fullUrl}" alt="preview"><div style="font-size:.78rem;color:var(--nl-muted);margin-top:4px;">Current: ${img}</div>`;
      } else {
        previewBox.innerHTML = `<video src="${fullUrl}" controls></video><div style="font-size:.78rem;color:var(--nl-muted);margin-top:4px;">Current: ${img}</div>`;
      }
    }

    return row;
  }

  function reindexRows() {
    const rows = document.querySelectorAll('#messageRows .nl-msg-card');
    rows.forEach((row, i) => {
      const num = i + 1;
      row.dataset.msgNum = num;
      row.querySelector('.nl-msg-num').textContent = num;
      row.querySelector('[data-field="msg_type"]').name     = `multinewsletter_${OPT_INDEX}_msg_type_${num}`;
      row.querySelector('[data-field="message"]').name      = `multinewsletter_${OPT_INDEX}_message_${num}`;
      row.querySelector('[data-field="file"]').name         = `multinewsletter_${OPT_INDEX}_file_${num}`;
      row.querySelector('[data-field="file_hidden"]').name  = `multinewsletter_${OPT_INDEX}_file_${num}_hidden`;
      row.querySelector('[data-field="delay"]').name        = `multinewsletter_${OPT_INDEX}_${num}`;
      const rmBtn = row.querySelector('.nl-remove-row');
      rmBtn.disabled = (num === 1);
    });
  }

  /* ---------- Drag-and-drop reordering ---------- */
  let dragSrc = null;
  const msgList = document.getElementById('messageRows');

  msgList.addEventListener('dragstart', e => {
    const card = e.target.closest('.nl-msg-card');
    if (!card) return;
    dragSrc = card;
    card.classList.add('is-dragging');
    e.dataTransfer.effectAllowed = 'move';
  });
  msgList.addEventListener('dragend', e => {
    const card = e.target.closest('.nl-msg-card');
    if (card) card.classList.remove('is-dragging');
    dragSrc = null;
  });
  msgList.addEventListener('dragover', e => {
    e.preventDefault();
    const over = e.target.closest('.nl-msg-card');
    if (!over || over === dragSrc) return;
    const rect = over.getBoundingClientRect();
    const after = (e.clientY - rect.top) > rect.height / 2;
    msgList.insertBefore(dragSrc, after ? over.nextSibling : over);
  });
  msgList.addEventListener('drop', () => reindexRows());

  /* ---------- Add / Remove row buttons (event delegation) ---------- */
  msgList.addEventListener('click', e => {
    const btn = e.target.closest('.nl-remove-row');
    if (!btn || btn.disabled) return;
    const card = btn.closest('.nl-msg-card');
    if (document.querySelectorAll('#messageRows .nl-msg-card').length > 1) {
      card.remove();
      reindexRows();
    }
  });

  document.getElementById('addMessageRow').addEventListener('click', () => {
    const count = document.querySelectorAll('#messageRows .nl-msg-card').length + 1;
    msgList.appendChild(buildRow(count));
  });

  /* ---------- Init with one row ---------- */
  msgList.appendChild(buildRow(1));

  /* ---------- Debounced search ---------- */
  function debounce(fn, wait=250) {
    let t;
    return function (...args) {
      clearTimeout(t);
      t = setTimeout(() => fn.apply(this, args), wait);
    };
  }
  const searchInput = document.getElementById('filter_name');
  if (searchInput) {
    searchInput.addEventListener('input', debounce(() => {
      // Trigger the existing search pipeline (kept compatible with old handlers)
      const btn = document.querySelector('[data-update-user-search]');
      if (btn) btn.click();
    }, 350));
  }

  /* ---------- Submit handler ---------- */
  const submitBtn = document.getElementById('auto_message_save_multinewsletter_btn');
  submitBtn.addEventListener('click', () => {
    // Validation
    const rows = document.querySelectorAll('#messageRows .nl-msg-card');
    let valid = true;
    let firstError = '';

    rows.forEach((row, i) => {
      if (!valid) return;
      const num = i + 1;
      const type    = row.querySelector('[data-field="msg_type"]').value;
      const message = row.querySelector('[data-field="message"]').value.trim();
      const file    = row.querySelector('[data-field="file"]').files[0];
      const hidden  = row.querySelector('[data-field="file_hidden"]').value;
      const delay   = row.querySelector('[data-field="delay"]').value;

      if (!delay || delay === '0') {
        if (message || file || hidden) {
          firstError = `Please select a valid delay for message ${num}`;
          valid = false;
          return;
        }
      }
      if (type === 'text' && !message) {
        firstError = `Please enter text for message ${num}`;
        valid = false;
        return;
      }
      if (type === 'image' && !file && !hidden) {
        firstError = `Please select a file for message ${num}`;
        valid = false;
        return;
      }
      if (type === 'text_image' && (!message || (!file && !hidden))) {
        firstError = `Please provide both text and file for message ${num}`;
        valid = false;
        return;
      }
      if ((type === 'image' || type === 'text_image') && file) {
        const ext = file.name.split('.').pop().toLowerCase();
        if (!VALID_EXTS.includes(ext)) {
          firstError = `Invalid file type for message ${num}`;
          valid = false;
          return;
        }
      }
    });

    if (!valid) {
      toast(firstError || 'Validation failed', 'error');
      return;
    }

    // Confirm recipient selection (if your existing global state has it)
    if (typeof checkedUsers === 'undefined' || !checkedUsers || (Array.isArray(checkedUsers) && checkedUsers.length === 0)) {
      toast('Please select at least one recipient first.', 'warn');
      return;
    }
    if (typeof selectedFake === 'undefined' || !selectedFake || !selectedFake.id) {
      toast('Please select a fake user as sender.', 'warn');
      return;
    }

    const form = document.getElementById('auto_message_form_welcome');
    const formData = new FormData(form);
    formData.append('to', checkedUsers);
    formData.append('fkidu', selectedFake.id);

    submitBtn.disabled = true;
    const originalLabel = submitBtn.innerHTML;
    submitBtn.innerHTML = '<i class="material-icons" style="font-size:18px;animation:nlSpin 1s linear infinite;">progress_activity</i> Sending...';

    fetch(request_source() + '/multi_newsletter_users_new.php', {
      method: 'POST',
      body: formData,
    })
    .then(r => r.json().catch(() => ({ status:'error', message:'Invalid server response' })))
    .then(data => {
      if (data.status === 'success' || data.success === 1) {
        toast('Newsletter created successfully! Redirecting…', 'success');
        setTimeout(() => location.reload(), 2000);
      } else {
        toast(data.message || 'Failed to create newsletter', 'error');
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalLabel;
      }
    })
    .catch(err => {
      console.error(err);
      toast('Network error — please retry', 'error');
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalLabel;
    });
  });

  /* ---------- Check-all delegation ---------- */
  const checkAllBox = document.getElementById('nlCheckAll');
  if (checkAllBox) {
    checkAllBox.addEventListener('change', function () {
      document.querySelectorAll('#usersTable input[type=checkbox]').forEach(cb => {
        cb.checked = this.checked;
        cb.closest('tr')?.classList.toggle('is-checked', this.checked);
      });
    });
  }

  /* ---------- Search button — wire to existing pipeline ---------- */
  const searchBtn = document.getElementById('nlSearchBtn');
  if (searchBtn) {
    searchBtn.addEventListener('click', () => {
      const oldBtn = document.querySelector('[data-update-user-search]');
      if (oldBtn) oldBtn.click();
    });
  }

  /* ---------- Compose button — scroll to composer ---------- */
  const composeBtn = document.getElementById('nlComposeBtn');
  if (composeBtn) {
    composeBtn.addEventListener('click', () => {
      document.getElementById('nlComposer').scrollIntoView({ behavior:'smooth', block:'start' });
    });
  }

  /* ---------- Select2 init ---------- */
  if (window.jQuery && typeof $.fn.select2 === 'function') {
    $('.js-example-basic-multiple').select2({ width:'100%' });
  }

  /* ---------- Spinner keyframes ---------- */
  const styleTag = document.createElement('style');
  styleTag.textContent = '@keyframes nlSpin{to{transform:rotate(360deg)}}';
  document.head.appendChild(styleTag);
})();
</script>