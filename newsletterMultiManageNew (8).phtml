<div class="nlm-toast-wrap" id="nlmToastWrap"></div>

<script>
(function () {
  'use strict';

  const VALID_EXTS = ['jpg','jpeg','png','gif','bmp','webp','tiff','mp4','webm','ogg','mov','avi','mkv','flv'];
  const DELAY_OPTIONS = [
    {label:'-- Select --', value:0},
    ...Array.from({length:60}, (_,i)=>({label:`${i+1} Min`, value:i+1})),
    {label:'1 Hour',  value:60},
    {label:'3 Hours', value:180},
    {label:'6 Hours', value:360},
    {label:'9 Hours', value:540},
    {label:'12 Hours',value:720},
    {label:'1 Day',   value:1440},
    {label:'2 Days',  value:2880},
    {label:'3 Days',  value:4320},
    {label:'1 Week',  value:10080},
  ];

  /* ---------- State ---------- */
  let lazyOffset   = <?= NL_PAGE_SIZE ?>;
  let lazyLoading  = false;
  let lazyHasMore  = <?= $hasMoreInitial ? 'true' : 'false' ?>;
  let currentSearch  = '';
  let currentStatus  = 'all';
  /* Snapshot of pre-edit state for history logging */
  let preEditSnapshot = null;

  /* ---------- Toast ---------- */
  function toast(msg, type='info') {
    const wrap = document.getElementById('nlmToastWrap');
    const el = document.createElement('div');
    el.className = `nlm-toast nlm-toast--${type}`;
    const icon = type==='success'?'check_circle':type==='error'?'error':type==='warn'?'warning':'info';
    const colorVar = type==='warn'?'warn':type==='error'?'danger':type==='success'?'success':'primary';
    el.innerHTML = `
      <i class="material-icons" style="color:var(--nl-${colorVar});">${icon}</i>
      <div class="nlm-toast__msg">${msg}</div>
      <button class="nlm-toast__close">&times;</button>
    `;
    el.querySelector('.nlm-toast__close').addEventListener('click', () => el.remove());
    wrap.appendChild(el);
    setTimeout(() => { el.style.opacity='0'; el.style.transform='translateX(20px)'; setTimeout(()=>el.remove(),300); }, 4500);
  }
  window.dislayAlert = (m) => toast(m, 'info');

  /* ---------- Modal helpers ---------- */
  /* Move all modals to <body> so they escape the MDK drawer-layout's CSS-transform
     stacking context — transforms on a parent trap position:fixed children,
     preventing them from covering the full viewport and the sidebar. */
  document.querySelectorAll('.nlm-modal').forEach(m => document.body.appendChild(m));

  function openModal(id) {
    const m = document.getElementById(id);
    /* Re-append in case something moved it back */
    if (m.parentNode !== document.body) document.body.appendChild(m);
    m.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }
  function closeModal(id) {
    document.getElementById(id).classList.remove('is-open');
    document.body.style.overflow = '';
  }
  document.querySelectorAll('[data-close]').forEach(b => b.addEventListener('click', () => {
    document.querySelectorAll('.nlm-modal.is-open').forEach(m => m.classList.remove('is-open'));
    document.body.style.overflow = '';
  }));
  document.querySelectorAll('.nlm-modal').forEach(m => m.addEventListener('click', e => {
    if (e.target === m) { m.classList.remove('is-open'); document.body.style.overflow = ''; }
  }));
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.nlm-modal.is-open').forEach(m => m.classList.remove('is-open'));
      document.body.style.overflow = '';
    }
  });

  /* ======================================================================
   * INFINITE SCROLL — IntersectionObserver on sentinel element
   * ====================================================================== */
  const grid     = document.getElementById('nlmGrid');
  const sentinel = document.getElementById('nlmSentinel');

  function setSentinelLoading(loading, done) {
    if (done) {
      sentinel.innerHTML = '<span style="display:flex;align-items:center;gap:8px;color:var(--nl-muted);opacity:.6;"><i class="material-icons" style="font-size:20px;">check_circle</i> All newsletters loaded</span>';
      lazyHasMore = false;
    } else if (loading) {
      sentinel.innerHTML = '<i class="material-icons" style="animation:nlSpin 1s linear infinite;font-size:24px;">progress_activity</i><span>Loading more newsletters…</span>';
    } else {
      sentinel.innerHTML = '';
    }
  }

  function loadMore() {
    if (lazyLoading || !lazyHasMore) return;
    lazyLoading = true;
    setSentinelLoading(true);

    const params = new URLSearchParams({
      action: 'lazy_load',
      limit:  PAGE_SIZE,
      offset: lazyOffset,
      search: currentSearch,
      status: currentStatus,
    });

    fetch(AJAX_URL, { method:'POST', body: params })
      .then(r => r.json())
      .then(res => {
        if (res.status !== 'success') { toast('Failed to load more', 'error'); return; }

        /* Append cards before the sentinel */
        const temp = document.createElement('div');
        temp.innerHTML = res.html;
        while (temp.firstChild) {
          grid.insertBefore(temp.firstChild, sentinel);
        }

        /* Append data to NEWSLETTERS array for card actions */
        if (res.data) res.data.forEach(d => NEWSLETTERS.push(d));

        lazyOffset = res.offset;
        lazyHasMore = res.hasMore;
        lazyLoading = false;

        if (!lazyHasMore) setSentinelLoading(false, true);
        else setSentinelLoading(false);
      })
      .catch(() => {
        toast('Network error while loading more', 'error');
        lazyLoading = false;
        setSentinelLoading(false);
      });
  }

  const scrollObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting && lazyHasMore && !lazyLoading) {
        loadMore();
      }
    });
  }, { rootMargin: '200px' });

  scrollObserver.observe(sentinel);

  /* ======================================================================
   * SERVER-SIDE SEARCH + FILTER  (replaces client-side filtering)
   * ====================================================================== */
  const searchInput  = document.getElementById('nlmSearch');
  const statusFilter = document.getElementById('nlmFilterStatus');
  let searchDebounce;

  function serverSearch() {
    const q = searchInput.value.trim().toLowerCase();
    const s = statusFilter.value;

    /* If nothing changed, skip */
    if (q === currentSearch && s === currentStatus) return;
    currentSearch = q;
    currentStatus = s;
    lazyOffset = 0;
    lazyHasMore = true;
    lazyLoading = false;

    /* Remove existing cards but keep sentinel */
    grid.querySelectorAll('.nlm-card').forEach(c => c.remove());
    /* Clear NEWSLETTERS array */
    NEWSLETTERS.length = 0;

    setSentinelLoading(true);

    const params = new URLSearchParams({
      action: 'lazy_load',
      limit:  PAGE_SIZE,
      offset: 0,
      search: currentSearch,
      status: currentStatus,
    });

    fetch(AJAX_URL, { method:'POST', body: params })
      .then(r => r.json())
      .then(res => {
        if (res.status !== 'success') { toast('Search failed', 'error'); return; }

        const temp = document.createElement('div');
        temp.innerHTML = res.html;
        while (temp.firstChild) {
          grid.insertBefore(temp.firstChild, sentinel);
        }

        if (res.data) res.data.forEach(d => NEWSLETTERS.push(d));

        lazyOffset = res.offset;
        lazyHasMore = res.hasMore;

        if (res.total === 0) {
          grid.insertBefore(
            Object.assign(document.createElement('div'), {
              className: 'nlm-empty',
              innerHTML: '<i class="material-icons">search_off</i><h3>No results found</h3><p>Try adjusting your search or filter criteria.</p>'
            }),
            sentinel
          );
          setSentinelLoading(false);
          lazyHasMore = false;
        } else if (!lazyHasMore) {
          setSentinelLoading(false, true);
        } else {
          setSentinelLoading(false);
        }
      })
      .catch(() => {
        toast('Search failed — network error', 'error');
        setSentinelLoading(false);
      });
  }

  searchInput.addEventListener('input', () => {
    clearTimeout(searchDebounce);
    searchDebounce = setTimeout(serverSearch, 300);
  });
  statusFilter.addEventListener('change', serverSearch);

  /* ---------- Build an edit-row ---------- */
  function buildEditRow(num, data = {}) {
    const row = document.createElement('div');
    row.className = 'nlm-msg-card';
    row.draggable = true;
    row.dataset.msgNum = num;

    const type = data.type || 'text';
    const text = data.text || '';
    const delay = data.delay ?? 0;
    const img = data.image || '';

    const delayOpts = DELAY_OPTIONS.map(o =>
      `<option value="${o.value}" ${Number(delay)===o.value?'selected':''}>${o.label}</option>`
    ).join('');
    const typeOpts = ['text','image','text_image'].map(t =>
      `<option value="${t}" ${t===type?'selected':''}>${t==='text_image'?'Text + File':t.charAt(0).toUpperCase()+t.slice(1)}</option>`
    ).join('');

    row.innerHTML = `
      <div class="nlm-msg-card__head">
        <div class="nlm-msg-num" title="Drag to reorder">${num}</div>
        <select data-field="msg_type" name="multinewsletter_mt_msg_type_${num}">${typeOpts}</select>
        <div class="nlm-msg-delay">
          <label>Delay</label>
          <select data-field="delay" name="multinewsletter_mt_${num}">${delayOpts}</select>
        </div>
        <button type="button" class="nlm-remove-row" title="Remove" ${num===1?'disabled':''}>
          <i class="material-icons">delete</i>
        </button>
      </div>
      <div class="nlm-msg-body" style="display:grid;grid-template-columns:1fr;gap:10px;">
        <textarea data-field="message" name="multinewsletter_mt_message_${num}"
                  placeholder="Type your message..." style="display:${type==='image'?'none':'block'};">${text}</textarea>
        <label class="nlm-file-zone" style="display:${type==='text'?'none':'flex'};">
          <i class="material-icons" style="color:var(--nl-muted);">cloud_upload</i>
          <span>Click to upload image / video</span>
          <input type="file" data-field="file" name="multinewsletter_mt_file_${num}" accept="image/*,video/*">
          <input type="hidden" data-field="file_hidden" name="multinewsletter_mt_file_${num}_hidden" value="${img}">
        </label>
        <div class="nlm-file-preview" data-field="preview"></div>
      </div>
    `;

    const typeSel = row.querySelector('[data-field="msg_type"]');
    const fileInput = row.querySelector('[data-field="file"]');
    const fileZone = row.querySelector('.nlm-file-zone');
    const textarea = row.querySelector('[data-field="message"]');
    const previewBox = row.querySelector('[data-field="preview"]');

    typeSel.addEventListener('change', () => {
      const v = typeSel.value;
      textarea.style.display = (v === 'image') ? 'none' : 'block';
      fileZone.style.display = (v === 'text') ? 'none' : 'flex';
    });

    fileInput.addEventListener('change', () => {
      const f = fileInput.files[0];
      if (!f) return;
      const ext = f.name.split('.').pop().toLowerCase();
      if (!VALID_EXTS.includes(ext)) { toast(`Invalid file type: .${ext}`, 'error'); fileInput.value=''; return; }
      const url = URL.createObjectURL(f);
      if (f.type.startsWith('image/'))      previewBox.innerHTML = `<img src="${url}" alt="preview">`;
      else if (f.type.startsWith('video/')) previewBox.innerHTML = `<video src="${url}" controls></video>`;
      else                                  previewBox.innerHTML = `<div style="font-size:.82rem;color:var(--nl-muted);">${f.name}</div>`;
    });

    if (img) {
      const ext = img.split('.').pop().toLowerCase();
      const fullUrl = (SITE_URL + 'requests/' + img).replace(/\/+/g,'/');
      if (['jpg','jpeg','png','gif','bmp','webp','tiff'].includes(ext)) {
        previewBox.innerHTML = `<img src="${fullUrl}" alt="preview"><div style="font-size:.78rem;color:var(--nl-muted);margin-top:4px;">Current: ${img}</div>`;
      } else {
        previewBox.innerHTML = `<video src="${fullUrl}" controls></video><div style="font-size:.78rem;color:var(--nl-muted);margin-top:4px;">Current: ${img}</div>`;
      }
    }

    return row;
  }

  function reindexEditRows() {
    const rows = document.querySelectorAll('#editMessageRows .nlm-msg-card');
    rows.forEach((row, i) => {
      const num = i + 1;
      row.dataset.msgNum = num;
      row.querySelector('.nlm-msg-num').textContent = num;
      row.querySelector('[data-field="msg_type"]').name = `multinewsletter_mt_msg_type_${num}`;
      row.querySelector('[data-field="message"]').name  = `multinewsletter_mt_message_${num}`;
      row.querySelector('[data-field="file"]').name     = `multinewsletter_mt_file_${num}`;
      row.querySelector('[data-field="file_hidden"]').name = `multinewsletter_mt_file_${num}_hidden`;
      row.querySelector('[data-field="delay"]').name    = `multinewsletter_mt_${num}`;
      const rmBtn = row.querySelector('.nlm-remove-row');
      rmBtn.disabled = (num === 1);
    });
  }

  /* ---------- DnD on edit rows ---------- */
  let dragSrc = null;
  const editList = document.getElementById('editMessageRows');
  editList.addEventListener('dragstart', e => {
    const card = e.target.closest('.nlm-msg-card');
    if (!card) return;
    dragSrc = card; card.classList.add('is-dragging');
    e.dataTransfer.effectAllowed = 'move';
  });
  editList.addEventListener('dragend', e => {
    const card = e.target.closest('.nlm-msg-card');
    if (card) card.classList.remove('is-dragging');
    dragSrc = null;
  });
  editList.addEventListener('dragover', e => {
    e.preventDefault();
    const over = e.target.closest('.nlm-msg-card');
    if (!over || over === dragSrc) return;
    const rect = over.getBoundingClientRect();
    const after = (e.clientY - rect.top) > rect.height / 2;
    editList.insertBefore(dragSrc, after ? over.nextSibling : over);
  });
  editList.addEventListener('drop', () => reindexEditRows());

  editList.addEventListener('click', e => {
    const btn = e.target.closest('.nlm-remove-row');
    if (!btn || btn.disabled) return;
    const card = btn.closest('.nlm-msg-card');
    if (document.querySelectorAll('#editMessageRows .nlm-msg-card').length > 1) {
      card.remove(); reindexEditRows();
    }
  });

  document.getElementById('addEditMessageRow').addEventListener('click', () => {
    const count = document.querySelectorAll('#editMessageRows .nlm-msg-card').length + 1;
    editList.appendChild(buildEditRow(count));
  });

  /* ---------- Snapshot helper for edit history ---------- */
  function captureEditSnapshot() {
    const rows = document.querySelectorAll('#editMessageRows .nlm-msg-card');
    const snap = [];
    rows.forEach((row, i) => {
      const num  = i + 1;
      const type = row.querySelector('[data-field="msg_type"]').value;
      const text = row.querySelector('[data-field="message"]').value;
      const file = row.querySelector('[data-field="file_hidden"]').value;
      const delay = row.querySelector('[data-field="delay"]').value;
      snap.push({ message_num: num, type, text, file, delay });
    });
    return snap;
  }

  function computeEditDiff(oldSnap, newsletterId) {
    const rows = document.querySelectorAll('#editMessageRows .nlm-msg-card');
    const changes = [];
    rows.forEach((row, i) => {
      const num  = i + 1;
      const type = row.querySelector('[data-field="msg_type"]').value;
      const text = row.querySelector('[data-field="message"]').value;
      const file = row.querySelector('[data-field="file_hidden"]').value || (row.querySelector('[data-field="file"]').files[0] ? '[new file uploaded]' : '');
      const delay = row.querySelector('[data-field="delay"]').value;

      const old = oldSnap.find(s => s.message_num === num);
      if (!old) {
        changes.push({ message_num: num, field: 'message_added', old_value: '', new_value: `Type: ${type}, Delay: ${delay} min` });
        return;
      }
      if (old.text !== text)
        changes.push({ message_num: num, field: 'message_text', old_value: old.text, new_value: text });
      if (old.delay !== delay)
        changes.push({ message_num: num, field: 'delay_minutes', old_value: old.delay + ' min', new_value: delay + ' min' });
      if (old.type !== type)
        changes.push({ message_num: num, field: 'msg_type', old_value: old.type, new_value: type });
      if (old.file !== file)
        changes.push({ message_num: num, field: 'file', old_value: old.file || '(none)', new_value: file || '(none)' });
    });
    return changes;
  }

  /* ---------- Card actions (event delegation) ---------- */
  document.getElementById('nlmGrid').addEventListener('click', e => {
    const btn = e.target.closest('[data-action]');
    if (!btn) return;
    const action = btn.dataset.action;
    const id = parseInt(btn.dataset.id, 10);
    const nl = NEWSLETTERS.find(n => n.id === id);
    if (!nl && action !== 'history') return;

    if (action === 'view')       openViewModal(nl);
    else if (action === 'edit')  openEditModal(nl);
    else if (action === 'history') openHistoryModal(id);
    else if (action === 'stop')  confirmStop(nl);
    else if (action === 'delete') confirmDelete(nl);
  });

  /* ---------- View modal (fetches recipients) ---------- */
  function openViewModal(nl) {
    document.getElementById('nlmViewId').textContent = `#${nl.id}`;
    document.getElementById('nlmViewBody').innerHTML = `
      <div style="text-align:center;padding:40px;">
        <i class="material-icons" style="font-size:36px;color:var(--nl-muted);animation:nlSpin 1s linear infinite;">progress_activity</i>
        <div style="margin-top:12px;color:var(--nl-muted);">Loading recipients…</div>
      </div>`;
    openModal('nlmViewModal');

    fetch(SITE_URL + 'requests/multi_newsletter_users_new.php', {
      method: 'POST',
      headers: {'Content-Type': 'application/x-www-form-urlencoded'},
      body: new URLSearchParams({ newsletter_id: nl.id })
    })
    .then(r => r.text())
    .then(html => {
      document.getElementById('nlmViewBody').innerHTML = html || '<div class="nlm-empty">No recipients</div>';
    })
    .catch(() => {
      document.getElementById('nlmViewBody').innerHTML = '<div class="nlm-empty">Failed to load recipients</div>';
    });
  }

  /* ---------- Edit modal ---------- */
  function openEditModal(nl) {
    document.getElementById('nlmEditId').textContent = `#${nl.id}`;
    document.getElementById('editNewsletterId').val = nl.id;
    document.getElementById('editNewsletterId').setAttribute('value', nl.id);
    document.getElementById('editIndex').value = nl.id;

    const fkSelect = document.getElementById('editFakeUser');
    fkSelect.value = nl.fake_user_id;
    if (window.jQuery) $(fkSelect).trigger('change');

    editList.innerHTML = '';
    fetch(`${SITE_URL}requests/multi_newsletter_users_new.php?action=view_newsletter&id=${nl.id}`)
      .then(r => r.json())
      .then(data => {
        if (!data || !data.messages) {
          editList.appendChild(buildEditRow(1));
          preEditSnapshot = captureEditSnapshot();
          return;
        }
        data.messages.forEach((m, i) => {
          let messageData = {};
          try { messageData = m.message_text ? JSON.parse(m.message_text) : {}; } catch (e) {}
          editList.appendChild(buildEditRow(i+1, {
            type: m.msg_type,
            text: messageData.text || '',
            image: messageData.image || '',
            delay: m.delay_minutes ?? 0,
          }));
        });
        if (data.messages.length === 0) editList.appendChild(buildEditRow(1));
        /* Capture snapshot AFTER rows are rendered */
        preEditSnapshot = captureEditSnapshot();
      })
      .catch(() => {
        editList.appendChild(buildEditRow(1));
        preEditSnapshot = captureEditSnapshot();
        toast('Failed to load message details', 'error');
      });

    openModal('nlmEditModal');
  }

  /* ======================================================================
   * HISTORY MODAL
   * ====================================================================== */
  function openHistoryModal(newsletterId) {
    document.getElementById('nlmHistoryId').textContent = `#${newsletterId}`;
    document.getElementById('nlmHistoryBody').innerHTML = `
      <div style="text-align:center;padding:40px;">
        <i class="material-icons" style="font-size:36px;color:var(--nl-muted);animation:nlSpin 1s linear infinite;">progress_activity</i>
        <div style="margin-top:12px;color:var(--nl-muted);">Loading edit history…</div>
      </div>`;
    openModal('nlmHistoryModal');

    fetch(AJAX_URL, {
      method: 'POST',
      headers: {'Content-Type': 'application/x-www-form-urlencoded'},
      body: new URLSearchParams({ action: 'edit_history', newsletter_id: newsletterId })
    })
    .then(r => r.json())
    .then(res => {
      const body = document.getElementById('nlmHistoryBody');
      if (res.status !== 'success') {
        body.innerHTML = '<div class="nlm-history__empty"><i class="material-icons">error_outline</i><p>Failed to load history.</p></div>';
        return;
      }
      if (!res.history || res.history.length === 0) {
        body.innerHTML = '<div class="nlm-history__empty"><i class="material-icons">history</i><h3 style="margin:6px 0;">No edits recorded</h3><p>This newsletter has not been edited yet.</p></div>';
        return;
      }
      body.innerHTML = '<div class="nlm-history">' + res.history.map(renderHistoryEntry).join('') + '</div>';
    })
    .catch(() => {
      document.getElementById('nlmHistoryBody').innerHTML = '<div class="nlm-history__empty"><i class="material-icons">error_outline</i><p>Network error.</p></div>';
    });
  }

  function renderHistoryEntry(entry) {
    const dateStr = entry.edited_at ? formatDate(entry.edited_at) : 'Unknown date';
    const editor  = entry.editor_name || 'Unknown';
    const fieldLabels = {
      message_text: 'Message Text',
      delay_minutes: 'Delay',
      msg_type: 'Message Type',
      file: 'Attached File',
      message_added: 'Message Added',
      fake_user: 'Sender (Fake User)',
    };

    let changesHtml = entry.changes.map(ch => {
      const label = fieldLabels[ch.field_changed] || ch.field_changed;
      const badge = `<span class="nlm-history__change-badge">Msg #${ch.message_num || '?'}</span>`;

      if (ch.field_changed === 'message_added') {
        return `<div class="nlm-history__change">
          <div class="nlm-history__change-header">${badge} <strong>${label}</strong></div>
          <div class="nlm-history__diff">
            <div>
              <div class="nlm-history__diff-label nlm-history__diff-label--new">Added</div>
              <div class="nlm-history__diff-value nlm-history__diff-value--new">${escHtml(ch.new_value || '(no details)')}</div>
            </div>
          </div>
        </div>`;
      }

      const oldDisplay = ch.old_value ? escHtml(truncate(ch.old_value, 500)) : '<em style="color:var(--nl-muted);">(empty)</em>';
      const newDisplay = ch.new_value ? escHtml(truncate(ch.new_value, 500)) : '<em style="color:var(--nl-muted);">(empty)</em>';

      return `<div class="nlm-history__change">
        <div class="nlm-history__change-header">${badge} <strong>${label}</strong></div>
        <div class="nlm-history__diff">
          <div>
            <div class="nlm-history__diff-label nlm-history__diff-label--old">Before</div>
            <div class="nlm-history__diff-value nlm-history__diff-value--old">${oldDisplay}</div>
          </div>
          <div>
            <div class="nlm-history__diff-label nlm-history__diff-label--new">After</div>
            <div class="nlm-history__diff-value nlm-history__diff-value--new">${newDisplay}</div>
          </div>
        </div>
      </div>`;
    }).join('');

    return `<div class="nlm-history__entry">
      <div class="nlm-history__dot"><i class="material-icons" style="font-size:13px;">edit</i></div>
      <div class="nlm-history__meta">
        <span class="nlm-history__date">${dateStr}</span>
        <span class="nlm-history__editor">by <strong>${escHtml(editor)}</strong></span>
        <span style="font-size:.72rem;color:var(--nl-muted);margin-left:auto;">${entry.changes.length} change${entry.changes.length > 1 ? 's' : ''}</span>
      </div>
      ${changesHtml}
    </div>`;
  }

  function formatDate(dateStr) {
    try {
      const d = new Date(dateStr + 'Z');
      const now = new Date();
      const diffMs = now - d;
      const diffMin = Math.floor(diffMs / 60000);
      const diffHr  = Math.floor(diffMs / 3600000);
      const diffDay = Math.floor(diffMs / 86400000);

      let relative = '';
      if (diffMin < 1)       relative = 'Just now';
      else if (diffMin < 60) relative = diffMin + ' min ago';
      else if (diffHr < 24)  relative = diffHr + ' hr ago';
      else if (diffDay < 7)  relative = diffDay + ' day' + (diffDay > 1 ? 's' : '') + ' ago';
      else                   relative = d.toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' });

      const full = d.toLocaleDateString('en-US', {
        weekday:'short', month:'short', day:'numeric', year:'numeric',
        hour:'2-digit', minute:'2-digit'
      });
      return `${relative} <span style="color:var(--nl-muted);font-weight:400;">(${full})</span>`;
    } catch(e) { return dateStr; }
  }

  function truncate(str, max) {
    if (!str || str.length <= max) return str;
    return str.substring(0, max) + '…';
  }

  function escHtml(str) {
    if (!str) return '';
    const d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }

  /* ---------- Stop / Delete confirmations ---------- */
  function confirmStop(nl) {
    if (!window.jQuery || !$.confirm) { if (confirm(`Stop newsletter #${nl.id}?`)) doStop(nl); return; }
    $.confirm({
      title: 'Confirm Stop',
      content: `Stop newsletter <strong>#${nl.id}</strong>? All pending messages will be cancelled.`,
      buttons: { confirm: () => doStop(nl), cancel: () => {} }
    });
  }
  function doStop(nl) {
    fetch(SITE_URL + 'requests/multi_newsletter_users_new.php', {
      method:'POST',
      headers:{'Content-Type':'application/x-www-form-urlencoded'},
      body: new URLSearchParams({ action:'stop_newsletter', id: nl.id })
    })
    .then(r => r.json().catch(()=>({status:'error',message:'Invalid response'})))
    .then(res => {
      toast(res.message || 'Stopped', res.status==='success'?'success':'error');
      if (res.status === 'success') setTimeout(() => location.reload(), 1500);
    });
  }

  function confirmDelete(nl) {
    if (!window.jQuery || !$.confirm) { if (confirm(`Delete newsletter #${nl.id}?`)) doDelete(nl); return; }
    $.confirm({
      title: 'Confirm Delete',
      content: `Permanently delete newsletter <strong>#${nl.id}</strong>? This cannot be undone.`,
      buttons: { confirm: () => doDelete(nl), cancel: () => {} }
    });
  }
  function doDelete(nl) {
    fetch(SITE_URL + 'requests/multi_newsletter_users_new.php', {
      method:'POST',
      headers:{'Content-Type':'application/x-www-form-urlencoded'},
      body: new URLSearchParams({ action:'delete_newsletter', id: nl.id })
    })
    .then(r => r.json().catch(()=>({status:'error',message:'Invalid response'})))
    .then(res => {
      toast(res.message || 'Deleted', res.status==='success'?'success':'error');
      if (res.status === 'success') setTimeout(() => location.reload(), 1500);
    });
  }

  /* ---------- Save edit handler (with history logging) ---------- */
  document.getElementById('saveEditNewsletterBtn').addEventListener('click', () => {
    const rows = document.querySelectorAll('#editMessageRows .nlm-msg-card');
    let valid = true; let firstError = '';
    const newsletterId = document.getElementById('editNewsletterId').value;

    rows.forEach((row, i) => {
      if (!valid) return;
      const num = i + 1;
      const type    = row.querySelector('[data-field="msg_type"]').value;
      const message = row.querySelector('[data-field="message"]').value.trim();
      const file    = row.querySelector('[data-field="file"]').files[0];
      const hidden  = row.querySelector('[data-field="file_hidden"]').value;
      const delay   = row.querySelector('[data-field="delay"]').value;

      if (!delay || delay === '0') {
        if (message || file || hidden) { firstError = `Set a valid delay for message ${num}`; valid = false; return; }
      }
      if (type === 'text' && !message)       { firstError = `Enter text for message ${num}`; valid = false; return; }
      if (type === 'image' && !file && !hidden) { firstError = `Select file for message ${num}`; valid = false; return; }
      if (type === 'text_image' && (!message || (!file && !hidden))) { firstError = `Provide text + file for message ${num}`; valid = false; return; }
      if ((type === 'image' || type === 'text_image') && file) {
        const ext = file.name.split('.').pop().toLowerCase();
        if (!VALID_EXTS.includes(ext)) { firstError = `Invalid file type for message ${num}`; valid = false; return; }
      }
    });

    if (!valid) { toast(firstError || 'Validation failed', 'error'); return; }
    if (!$('#editFakeUser').val()) { toast('Please select fake user', 'warn'); return; }

    /* Compute diff BEFORE saving */
    const editDiff = preEditSnapshot ? computeEditDiff(preEditSnapshot, newsletterId) : [];

    const form = document.getElementById('editNewsletterForm');
    const formData = new FormData(form);
    const btn = document.getElementById('saveEditNewsletterBtn');
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<i class="material-icons" style="animation:nlSpin 1s linear infinite;">progress_activity</i> Saving...';

    fetch(SITE_URL + 'requests/multi_newsletter_users_new.php', {
      method:'POST', body: formData
    })
    .then(r => r.json().catch(()=>({status:'error',message:'Invalid response'})))
    .then(res => {
      toast(res.message || 'Saved', res.status==='success'?'success':'error');
      if (res.status === 'success') {
        /* Log the edit history in background */
        if (editDiff.length > 0) {
          fetch(AJAX_URL, {
            method: 'POST',
            headers: {'Content-Type': 'application/x-www-form-urlencoded'},
            body: new URLSearchParams({
              action: 'log_edit',
              newsletter_id: newsletterId,
              changes: JSON.stringify(editDiff),
            })
          }).catch(() => {}); /* silent fail — don't block the user */
        }
        closeModal('nlmEditModal');
        setTimeout(() => location.reload(), 1200);
      } else {
        btn.disabled = false;
        btn.innerHTML = orig;
      }
    })
    .catch(err => {
      console.error(err);
      toast('Network error', 'error');
      btn.disabled = false;
      btn.innerHTML = orig;
    });
  });

  /* ---------- Select2 init ---------- */
  if (window.jQuery && typeof $.fn.select2 === 'function') {
    $('.js-example-basic-single').select2({ width:'100%', dropdownAutoWidth:true });
  }

  /* ---------- Spinner keyframes ---------- */
  const styleTag = document.createElement('style');
  styleTag.textContent = '@keyframes nlSpin{to{transform:rotate(360deg)}}';
  document.head.appendChild(styleTag);
})();
</script>