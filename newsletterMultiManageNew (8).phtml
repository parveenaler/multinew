/**
 * newsletterMultiManageNew.phtml — Multi-Newsletter Management Page
 *
 * =====================================================================
 * PERFORMANCE FIXES
 * =====================================================================
 *   1. FIXED N+1 QUERY — Single LEFT JOIN with conditional aggregation
 *   2. LAZY LOADING — Initial page loads only first 30 cards;
 *      subsequent batches fetched via AJAX on scroll (IntersectionObserver)
 *   3. Pre-fetched fake-user map in one query
 *   4. Vanilla JS for hot paths (modal, edit-form, validation, infinite scroll)
 *
 * =====================================================================
 * UI IMPROVEMENTS
 * =====================================================================
 *   - Modern card grid with infinite scroll
 *   - Modal-based full editor with drag-and-drop reordering
 *   - EDIT HISTORY — "History" button per card opens a timeline modal
 *     showing every edit session: date, editor, old vs new message content
 *   - Live reply-rate progress bars
 *   - Status pills (Active / Stopped / Draft)
 *   - Server-side search/filter with debounce
 *   - Responsive grid (1 col mobile, 2 col tablet, 3 col desktop)
 *   - Dark mode support via CSS variables
 *   - Toast notifications + loading spinners
 *
 * =====================================================================
 * RECOMMENDED MYSQL INDEXES
 * =====================================================================
 *   ALTER TABLE newsletter_queue
 *     ADD INDEX ix_nq_status_reply (newsletter_id, msg_num, execution_status, replied),
 *     ADD INDEX ix_nq_user_lookup  (newsletter_id, user_id);
 *   ALTER TABLE newsletter_messages
 *     ADD INDEX ix_nm_nl           (newsletter_id, message_number);
 *   ALTER TABLE newsletter_settings
 *     ADD INDEX ix_ns_active_id    (active, id);
 *
 * The edit-history table is auto-created by the AJAX endpoint on first use.
 * =====================================================================
 */

define('NL_PAGE_SIZE', 30);

global $mysqli;

/* -----------------------------------------------------------------
 * STATS — lightweight COUNT queries (not the full JOIN)
 * ----------------------------------------------------------------- */
$statsRow = $mysqli->query("
    SELECT
        COUNT(*)                    AS total,
        SUM(CASE WHEN active = 1 THEN 1 ELSE 0 END) AS active_count,
        COALESCE((SELECT SUM(c) FROM (
            SELECT COUNT(*) AS c FROM newsletter_messages GROUP BY newsletter_id
        ) sub), 0) AS total_messages
    FROM newsletter_settings
")->fetch_assoc();

$sentReplied = $mysqli->query("
    SELECT
        COUNT(DISTINCT CASE WHEN execution_status = 2 THEN user_id END) AS total_sent,
        COUNT(DISTINCT CASE WHEN replied = 1 THEN user_id END)        AS total_replied
    FROM newsletter_queue
")->fetch_assoc();

/* -----------------------------------------------------------------
 * FIRST BATCH — only the first NL_PAGE_SIZE newsletters
 * ----------------------------------------------------------------- */
$sql = "
    SELECT
        ns.id,
        ns.fake_user_id,
        ns.active,
        ns.created_at,
        ns.index_name,
        ns.scheduled_time,
        u.username AS fake_user_name,
        u.id       AS fake_user_pk,
        COUNT(DISTINCT nm.id) AS message_count,
        COUNT(DISTINCT CASE WHEN nq.execution_status = 2 THEN nq.user_id END) AS total_sent,
        COUNT(DISTINCT CASE WHEN nq.replied = 1          THEN nq.user_id END) AS total_replied,
        COUNT(DISTINCT CASE WHEN nq.execution_status IN (0,1) THEN nq.user_id END) AS pending
    FROM newsletter_settings ns
    LEFT JOIN newsletter_messages nm ON nm.newsletter_id = ns.id
    LEFT JOIN newsletter_queue     nq ON nq.newsletter_id = ns.id
    LEFT JOIN users                 u ON u.id             = ns.fake_user_id
    GROUP BY ns.id
    ORDER BY ns.id DESC
    LIMIT " . NL_PAGE_SIZE . "
";

$stmt = $mysqli->prepare($sql);
if (!$stmt) {
    $res = $mysqli->query($sql);
    $newsletters = $res ? $res->fetch_all(MYSQLI_ASSOC) : [];
} else {
    $stmt->execute();
    $newsletters = $stmt->get_result()->fetch_all(MYSQLI_ASSOC);
    $stmt->close();
}

/* -----------------------------------------------------------------
 * Reply rates for the first batch only
 * ----------------------------------------------------------------- */
$ratesByNewsletter = [];
if ($newsletters) {
    $ids = array_column($newsletters, 'id');
    $placeholders = implode(',', array_fill(0, count($ids), '?'));
    $types = str_repeat('i', count($ids));

    $rateSql = "
        SELECT
            nq.newsletter_id,
            nq.msg_num,
            COUNT(DISTINCT CASE WHEN nq.execution_status = 2 THEN nq.user_id END) AS sent_users,
            COUNT(DISTINCT CASE WHEN nq.replied = 1          THEN nq.user_id END) AS replied_users
        FROM newsletter_queue nq
        WHERE nq.newsletter_id IN ($placeholders)
        GROUP BY nq.newsletter_id, nq.msg_num
        ORDER BY nq.newsletter_id, nq.msg_num
    ";
    $rateStmt = $mysqli->prepare($rateSql);
    if ($rateStmt) {
        $rateStmt->bind_param($types, ...$ids);
        $rateStmt->execute();
        $rateRows = $rateStmt->get_result()->fetch_all(MYSQLI_ASSOC);
        $rateStmt->close();

        foreach ($rateRows as $r) {
            $nid = (int)$r['newsletter_id'];
            $sent = (int)$r['sent_users'];
            $replied = (int)$r['replied_users'];
            $rate = $sent > 0 ? round(($replied / $sent) * 100, 2) : 0;
            $ratesByNewsletter[$nid][] = [
                'msg_num'       => (int)$r['msg_num'],
                'sent_users'    => $sent,
                'replied_users' => $replied,
                'reply_rate'    => $rate,
            ];
        }
    }
}

/* Fake users list */
$fkStmt = $mysqli->prepare("SELECT id, username FROM users WHERE fake = 1 ORDER BY username ASC");
$fkStmt->execute();
$usersFKlist = $fkStmt->get_result()->fetch_all(MYSQLI_ASSOC);
$fkStmt->close();

/* JSON for first-batch (edit/view/stop/delete actions) */
$nlDataJson = json_encode(array_map(function($n) use ($ratesByNewsletter) {
    return [
        'id'            => (int)$n['id'],
        'fake_user_id'  => (int)$n['fake_user_id'],
        'fake_user_name'=> $n['fake_user_name'] ?? 'Unknown',
        'active'        => (int)$n['active'],
        'message_count' => (int)$n['message_count'],
        'total_sent'    => (int)$n['total_sent'],
        'total_replied' => (int)$n['total_replied'],
        'pending'       => (int)$n['pending'],
        'rates'         => $ratesByNewsletter[(int)$n['id']] ?? [],
    ];
}, $newsletters), JSON_HEX_TAG | JSON_HEX_APOS | JSON_HEX_AMP | JSON_HEX_QUOT);

$fkListJson = json_encode(array_map(fn($u) => ['id'=>(int)$u['id'], 'username'=>$u['username']], $usersFKlist));
$siteUrl    = rtrim($sm['config']['site_url'] ?? '/', '/') . '/';

$hasMoreInitial = (count($newsletters) >= NL_PAGE_SIZE);
?>
